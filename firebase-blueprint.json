{
  "entities": {
    "Table": {
      "title": "Table",
      "description": "Represents a physical table in the restaurant.",
      "type": "object",
      "properties": {
        "number": {
          "type": "number",
          "description": "The table number."
        },
        "status": {
          "type": "string",
          "enum": ["available", "occupied", "reserved"],
          "description": "The current status of the table."
        },
        "capacity": {
          "type": "number",
          "description": "The seating capacity of the table."
        },
        "active": {
          "type": "boolean",
          "description": "Whether the table is currently active/in-use."
        },
        "openedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the table was opened/occupied."
        },
        "currentSessionId": {
          "type": "string",
          "description": "The ID of the active session (comanda) for this table."
        }
      },
      "required": ["number", "status", "capacity"]
    },
    "Session": {
      "title": "Session",
      "description": "Represents an active tab/comanda for a table.",
      "type": "object",
      "properties": {
        "tableId": {
          "type": "string",
          "description": "The table number associated with this session."
        },
        "status": {
          "type": "string",
          "enum": ["active", "closed"],
          "description": "The current status of the session."
        },
        "openedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the session was opened."
        }
      },
      "required": ["tableId", "status", "openedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer's order.",
      "type": "object",
      "properties": {
        "tableId": {
          "type": "string",
          "description": "The ID of the table placing the order."
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/entities/OrderItem"
          },
          "description": "The list of items in the order."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "preparing", "ready", "served", "paid"],
          "description": "The current status of the order."
        },
        "totalAmount": {
          "type": "number",
          "description": "The total cost of the order."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the order was created."
        }
      },
      "required": ["tableId", "items", "status", "totalAmount", "createdAt"]
    },
    "OrderItem": {
      "title": "OrderItem",
      "description": "Represents a single item within an order.",
      "type": "object",
      "properties": {
        "menuItemId": {
          "type": "string",
          "description": "The ID of the menu item."
        },
        "name": {
          "type": "string",
          "description": "The name of the menu item."
        },
        "quantity": {
          "type": "number",
          "description": "The quantity ordered."
        },
        "price": {
          "type": "number",
          "description": "The price per unit."
        },
        "notes": {
          "type": "string",
          "description": "Special instructions or notes for this item."
        }
      },
      "required": ["menuItemId", "name", "quantity", "price"]
    },
    "MenuItem": {
      "title": "MenuItem",
      "description": "Represents an item on the restaurant's menu.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the menu item."
        },
        "description": {
          "type": "string",
          "description": "A description of the menu item."
        },
        "price": {
          "type": "number",
          "description": "The price of the menu item."
        },
        "category": {
          "type": "string",
          "description": "The category of the menu item (e.g., 'Appetizers', 'Mains', 'Drinks')."
        },
        "imageUrl": {
          "type": "string",
          "description": "URL to an image of the menu item."
        },
        "available": {
          "type": "boolean",
          "description": "Whether the item is currently available."
        }
      },
      "required": ["name", "price", "category", "available"]
    },
    "User": {
      "title": "User",
      "description": "Represents a staff member.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "waiter", "kitchen", "cashier"],
          "description": "The user's role in the system."
        }
      },
      "required": ["name", "email", "role"]
    }
  },
  "firestore": {
    "tables": {
      "schema": "#/entities/Table",
      "description": "Collection of all tables in the restaurant."
    },
    "sessions": {
      "schema": "#/entities/Session",
      "description": "Collection of active and closed sessions (comandas)."
    },
    "orders": {
      "schema": "#/entities/Order",
      "description": "Collection of all orders."
    },
    "menuItems": {
      "schema": "#/entities/MenuItem",
      "description": "Collection of all menu items."
    },
    "users": {
      "schema": "#/entities/User",
      "description": "Collection of all staff users."
    }
  }
}
