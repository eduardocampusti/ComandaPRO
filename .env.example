# Supabase
# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini AI Configuration
VITE_GEMINI_API_KEY=your-gemini-api-key

# App Configuration
PORT=3000
HOST=0.0.0.0

# Modo de Teste (Bypass de Assinatura)
# APENAS FUNCIONA EM AMBIENTE DE DESENVOLVIMENTO (import.meta.env.DEV)
# Setar para "true" para acessar o dashboard sem assinatura ativa localmente
VITE_BYPASS_SUBSCRIPTION_CHECK=true
